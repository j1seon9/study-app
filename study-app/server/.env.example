# 서버 설정
PORT=5000
NODE_ENV=development

# MongoDB (별도 서버, 1GB, 데이터 유지)
MONGO_URI=mongodb://<user>:<password>@<host>:<port>/study-app

# JWT 설정
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_long_random_string
JWT_REFRESH_EXPIRES_IN=7d

# CORS 허용 origin (프론트엔드 배포 주소)
CLIENT_ORIGIN=http://localhost:5173

# AI 마이크로서비스 (FastAPI, aiproject) 연동
AI_API_URL=http://127.0.0.1:8000
AI_API_KEY=change_this_to_a_shared_secret
AI_API_TIMEOUT_MS=10000
